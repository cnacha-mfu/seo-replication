<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://senso-framework.org/ontology/seo/seo-metrics"
         xmlns="http://senso-framework.org/ontology/seo/seo-metrics#">

<owl:Ontology rdf:about="http://senso-framework.org/ontology/seo/seo-metrics">
  <owl:imports rdf:resource="http://senso-framework.org/ontology/seo/seo-entities"/>
  <owl:imports rdf:resource="http://senso-framework.org/ontology/seo/seo-processes"/>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#hasComplexity">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#SoftwareProject"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Module"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#File"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Function"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#ComplexityMetric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSize">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#SoftwareProject"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Module"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#File"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#SizeMetric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasCoupling">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Module"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#File"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#CouplingMetric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasCohesion">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Module"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#File"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#CohesionMetric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasActivity">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#SoftwareProject"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Module"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#ActivityMetric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#measuredAt">
  <rdfs:domain rdf:resource="#Metric"/>
  <rdfs:range rdf:resource="http://senso-framework.org/ontology/seo/seo-entities#Version"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#metricValue">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Metric"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Metric">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#ComplexityMetric">
  <rdfs:subClassOf rdf:resource="#Metric"/>
</owl:Class>

<owl:Class rdf:about="#SizeMetric">
  <rdfs:subClassOf rdf:resource="#Metric"/>
</owl:Class>

<owl:Class rdf:about="#CouplingMetric">
  <rdfs:subClassOf rdf:resource="#Metric"/>
</owl:Class>

<owl:Class rdf:about="#CohesionMetric">
  <rdfs:subClassOf rdf:resource="#Metric"/>
</owl:Class>

<owl:Class rdf:about="#ActivityMetric">
  <rdfs:subClassOf rdf:resource="#Metric"/>
</owl:Class>

<owl:Class rdf:about="#AgentContributionRatio">
  <rdfs:subClassOf rdf:resource="#Metric"/>
  <rdfs:comment xml:lang="en">Paper 1 — key metric for agent adoption.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AgentChurnRatio">
  <rdfs:subClassOf rdf:resource="#Metric"/>
</owl:Class>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#ComplexityMetric"/>
    <rdf:Description rdf:about="#SizeMetric"/>
    <rdf:Description rdf:about="#CouplingMetric"/>
    <rdf:Description rdf:about="#CohesionMetric"/>
    <rdf:Description rdf:about="#ActivityMetric"/>
    <rdf:Description rdf:about="#AgentContributionRatio"/>
    <rdf:Description rdf:about="#AgentChurnRatio"/>
  </owl:members>
</owl:AllDisjointClasses>


</rdf:RDF>
