<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://senso-framework.org/ontology/seo/seo-processes"
         xmlns="http://senso-framework.org/ontology/seo/seo-processes#">

<owl:Ontology rdf:about="http://senso-framework.org/ontology/seo/seo-processes">
  <owl:imports rdf:resource="http://senso-framework.org/ontology/seo/seo-entities"/>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#experiencesPhase">
  <rdfs:domain rdf:resource="http://senso-framework.org/ontology/seo/seo-entities#SoftwareProject"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#GrowthPhase"/>
        <rdf:Description rdf:about="#StabilizationPhase"/>
        <rdf:Description rdf:about="#DeclinePhase"/>
        <rdf:Description rdf:about="#AgentAssistedPhase"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasChange">
  <rdfs:domain rdf:resource="#EvolutionEpisode"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Commit"/>
        <rdf:Description rdf:about="#RefactoringEvent"/>
        <rdf:Description rdf:about="#ArchitecturalChange"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRefactoring">
  <rdfs:domain rdf:resource="http://senso-framework.org/ontology/seo/seo-entities#Version"/>
  <rdfs:range rdf:resource="#RefactoringEvent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#occursIn">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#EvolutionEpisode"/>
        <rdf:Description rdf:about="#RefactoringEvent"/>
        <rdf:Description rdf:about="#ArchitecturalChange"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="http://senso-framework.org/ontology/seo/seo-entities#Version"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#EvolutionEpisode">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:comment xml:lang="en">Paper 1 — groups related changes.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EvolutionPhase">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:comment xml:lang="en">Paper 1 — base class for evolution phases.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#GrowthPhase">
  <rdfs:subClassOf rdf:resource="#EvolutionPhase"/>
</owl:Class>

<owl:Class rdf:about="#StabilizationPhase">
  <rdfs:subClassOf rdf:resource="#EvolutionPhase"/>
</owl:Class>

<owl:Class rdf:about="#DeclinePhase">
  <rdfs:subClassOf rdf:resource="#EvolutionPhase"/>
</owl:Class>

<owl:Class rdf:about="#ChangeEvent">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:comment xml:lang="en">Paper 1 — base class for change events.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#RefactoringEvent">
  <rdfs:subClassOf rdf:resource="#ChangeEvent"/>
</owl:Class>

<owl:Class rdf:about="#ArchitecturalChange">
  <rdfs:subClassOf rdf:resource="#ChangeEvent"/>
</owl:Class>

<owl:Class rdf:about="#AgentAssistedPhase">
  <rdfs:subClassOf rdf:resource="#EvolutionPhase"/>
  <rdfs:comment xml:lang="en">Paper 1 — agent-aware evolution phase.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AgentAdoptionEvent">
  <rdfs:subClassOf rdf:resource="#ChangeEvent"/>
</owl:Class>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#RefactoringEvent"/>
    <rdf:Description rdf:about="#ArchitecturalChange"/>
    <rdf:Description rdf:about="#AgentAdoptionEvent"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#GrowthPhase"/>
    <rdf:Description rdf:about="#StabilizationPhase"/>
    <rdf:Description rdf:about="#DeclinePhase"/>
    <rdf:Description rdf:about="#AgentAssistedPhase"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#EvolutionEpisode"/>
    <rdf:Description rdf:about="#EvolutionPhase"/>
    <rdf:Description rdf:about="#ChangeEvent"/>
  </owl:members>
</owl:AllDisjointClasses>


</rdf:RDF>
