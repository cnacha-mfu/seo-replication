<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://senso-framework.org/ontology/seo/seo-patterns"
         xmlns="http://senso-framework.org/ontology/seo/seo-patterns#">

<owl:Ontology rdf:about="http://senso-framework.org/ontology/seo/seo-patterns">
  <owl:imports rdf:resource="http://senso-framework.org/ontology/seo/seo-entities"/>
  <owl:imports rdf:resource="http://senso-framework.org/ontology/seo/seo-processes"/>
  <owl:imports rdf:resource="http://senso-framework.org/ontology/seo/seo-metrics"/>
  <owl:imports rdf:resource="http://senso-framework.org/ontology/seo/seo-laws"/>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#exhibitsPattern">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#SoftwareProject"/>
        <rdf:Description rdf:about="http://senso-framework.org/ontology/seo/seo-entities#Version"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#EvolutionPattern"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#detectedAt">
  <rdfs:domain rdf:resource="#EvolutionPattern"/>
  <rdfs:range rdf:resource="http://senso-framework.org/ontology/seo/seo-entities#Version"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#patternSeverity">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#EvolutionPattern"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#EvolutionPattern">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:comment xml:lang="en">Paper 1 — base class for evolution patterns.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SustainableGrowth">
  <rdfs:subClassOf rdf:resource="#EvolutionPattern"/>
</owl:Class>

<owl:Class rdf:about="#TechnicalDebtAccumulation">
  <rdfs:subClassOf rdf:resource="#EvolutionPattern"/>
</owl:Class>

<owl:Class rdf:about="#BigBangRefactoring">
  <rdfs:subClassOf rdf:resource="#EvolutionPattern"/>
</owl:Class>

<owl:Class rdf:about="#GradualDecay">
  <rdfs:subClassOf rdf:resource="#EvolutionPattern"/>
</owl:Class>

<owl:Class rdf:about="#ArchitecturalErosion">
  <rdfs:subClassOf rdf:resource="#EvolutionPattern"/>
</owl:Class>

<owl:Class rdf:about="#AntiPattern">
  <rdfs:subClassOf rdf:resource="#EvolutionPattern"/>
  <rdfs:comment xml:lang="en">Paper 1 — base class for anti-patterns, adds depth to hierarchy.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#ShadowTechDebt">
  <rdfs:subClassOf rdf:resource="#AntiPattern"/>
  <rdfs:comment xml:lang="en">Paper 1 — Shadow Tech Debt: functional but architecture-blind code introduced by AI coding agents.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#DependencySprawl">
  <rdfs:subClassOf rdf:resource="#AntiPattern"/>
</owl:Class>

<owl:Class rdf:about="#RefactoringAvoidance">
  <rdfs:subClassOf rdf:resource="#AntiPattern"/>
</owl:Class>

<owl:Class rdf:about="#CopyPasteOverReuse">
  <rdfs:subClassOf rdf:resource="#AntiPattern"/>
</owl:Class>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#ShadowTechDebt"/>
    <rdf:Description rdf:about="#DependencySprawl"/>
    <rdf:Description rdf:about="#RefactoringAvoidance"/>
    <rdf:Description rdf:about="#CopyPasteOverReuse"/>
  </owl:members>
</owl:AllDisjointClasses>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#SustainableGrowth"/>
    <rdf:Description rdf:about="#TechnicalDebtAccumulation"/>
    <rdf:Description rdf:about="#BigBangRefactoring"/>
    <rdf:Description rdf:about="#GradualDecay"/>
    <rdf:Description rdf:about="#ArchitecturalErosion"/>
    <rdf:Description rdf:about="#AntiPattern"/>
  </owl:members>
</owl:AllDisjointClasses>


</rdf:RDF>
